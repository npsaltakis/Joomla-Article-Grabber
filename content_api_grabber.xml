<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>com_content_api_grabber</name>
    <author>Nick Psaltakis</author>
    <authorEmail>nickpsal@gmail.com</authorEmail>
    <creationDate>2026-06</creationDate>
    <copyright>(C) 2026 Nick Psaltakis</copyright>
    <license>GNU GPL v2 or later</license>
    <version>1.2.0</version>
    <description>COM_CONTENT_API_GRABBER_XML_DESCRIPTION</description>

    <namespace path="src">Nickpsal\Component\ContentApiGrabber</namespace>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>
    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>
    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <updateservers>
        <!-- Change USER/REPO below to your GitHub owner/repository. -->
        <server type="extension" priority="1" name="Joomla Article Grabber Updates">https://raw.githubusercontent.com/npsaltakis/Joomla-Article-Grabber/main/update.xml</server>
    </updateservers>

    <administration>
        <menu link="index.php?option=com_content_api_grabber">COM_CONTENT_API_GRABBER</menu>
        <submenu>
            <menu link="option=com_content_api_grabber&amp;view=remote">COM_CONTENT_API_GRABBER_SUBMENU_REMOTE</menu>
            <menu link="option=com_content_api_grabber&amp;view=sources">COM_CONTENT_API_GRABBER_SUBMENU_SOURCES</menu>
            <menu link="option=com_content_api_grabber&amp;view=history">COM_CONTENT_API_GRABBER_SUBMENU_HISTORY</menu>
            <menu link="option=com_content_api_grabber&amp;view=export">COM_CONTENT_API_GRABBER_SUBMENU_EXPORT</menu>
            <menu link="option=com_content_api_grabber&amp;view=import">COM_CONTENT_API_GRABBER_SUBMENU_IMPORT</menu>
        </submenu>
        <files folder="admin">
            <folder>forms</folder>
            <folder>language</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
            <filename>access.xml</filename>
            <filename>config.xml</filename>
        </files>
    </administration>
</extension>
